# ============================================
# 小雪AI伴侣 - 环境变量配置示例
# ============================================

# ------- DeepSeek API 配置 -------
# 获取你的 API key 从 https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here


# ------- 阿里云 TTS 语音输出配置 -------
# 使用阿里云智能语音交互服务，让AI能用甜美女声回复

# 阿里云 AccessKey ID（必填）
# 获取方式：登录阿里云控制台 -> 访问控制 -> 创建 AccessKey
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id_here

# 阿里云 AccessKey Secret（必填）
# 与 AccessKey ID 配对使用
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret_here

# 阿里云 TTS AppKey（必填）
# 获取方式：登录阿里云控制台 -> 智能语音交互 -> 创建项目 -> 获取 AppKey
ALIYUN_TTS_APP_KEY=your_aliyun_tts_app_key_here

# 音色选择（可选，默认为 xiaoyun 甜美活泼女声）
# 可选音色：
#   - xiaoyun: 甜美活泼女声（默认，推荐）
#   - xiaogang: 稳重男声
#   - xiaomei: 温柔女声
#   - xiaoyu: 知性女声
#   - xiaobei: 萌妹女声
ALIYUN_TTS_VOICE=xiaoyun

# 语速调整（可选，范围 -500 ~ 500，默认 0）
# 负值 = 慢速，正值 = 快速
ALIYUN_TTS_SPEECH_RATE=0

# 音调调整（可选，范围 -500 ~ 500，默认 0）
# 负值 = 低音，正值 = 高音
ALIYUN_TTS_PITCH_RATE=0

# 音量调整（可选，范围 0 ~ 100，默认 50）
ALIYUN_TTS_VOLUME=50


# ------- 可灵 AI 图片生成配置 -------
# 用于 AI 生成小雪形象图片
# 获取方式：登录 https://klingai.com 获取 API Key
KLING_API_KEY=your_kling_api_key_here


# ------- 阿里云百炼（CosyVoice TTS 语音合成） -------
# 用于让 AI 说出声音，支持情感化语音
# 获取方式：登录阿里云百炼控制台 -> 模型广场 -> API-KEY 管理
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 音色选择（推荐：longwan_v3 龙安欢）
COSYVOICE_VOICE=longwan_v3
# 模型版本（推荐：cosyvoice-v3-flash，支持情感指令）
COSYVOICE_MODEL=cosyvoice-v3-flash


# ------- 微信小程序配置 -------
# 微信小程序 AppID 和 AppSecret
# 获取方式：登录微信公众平台 -> 开发 -> 开发设置
WECHAT_APPID=your_wechat_appid_here
WECHAT_APPSECRET=your_wechat_appsecret_here

# 审核专用手机号（可选）
# 设置后该手机号登录跳过短信验证码，仅供小程序审核使用
REVIEW_PHONE=


# ------- 管理后台 -------
# 管理员登录密码
ADMIN_PASSWORD=your_admin_password_here


# ------- 使用说明 -------
# 1. 复制此文件为 .env.local
#    copy .env.local.example .env.local
#
# 2. 填写上述所有必填项（DEEPSEEK_API_KEY、阿里云配置）
#
# 3. 重启开发服务器
#    pnpm dev
#
# 4. 测试语音功能
#    - 在代码中调用 speak('你好') 函数
#    - 或查看 examples/voice-usage.ts 示例
#
# 5. 音频文件会自动保存到 audio/ 目录
#    - 文件命名格式：tts_{时间戳}_{文本哈希}.mp3
#    - 可以定期清理此目录释放空间
